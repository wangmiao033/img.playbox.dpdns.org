{
  "version": "2026.06.26.2",
  "description": "Image Hunter remote configuration. This file only contains data rules, no executable code.",
  "ui": {
    "minSizeDefault": 10,
    "sortBy": "area_desc",
    "maxDisplayImages": 800,
    "emptyTips": {
      "default": "没有匹配图片。先刷新网页，再点插件右上角刷新；也可以调低 Min size。",
      "wechat": "微信文章图片通常懒加载。先滚到图片位置，再点插件右上角刷新。",
      "ali213": "如果只想下载本游戏图片，点「正文图」或「大图」，再点下载当前筛选。"
    }
  },
  "generic": {
    "maxNodes": 3600,
    "maxHtmlMatches": 700,
    "attributes": [
      "src",
      "currentSrc",
      "href",
      "data-src",
      "data-original",
      "data-lazy",
      "data-url",
      "data-image",
      "data-img",
      "data-bg",
      "data-background",
      "data-actualsrc",
      "data-cover",
      "data-croporisrc",
      "data-img-src",
      "data-original-src"
    ],
    "imageUrlKeywords": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp",
      ".gif",
      ".svg",
      ".avif",
      "mmbiz.qpic.cn",
      "wx_fmt=",
      "imageMogr2"
    ]
  },
  "sites": {
    "m.ali213.net": {
      "enabled": true,
      "label": "游侠网移动页",
      "minSizeDefault": 80,
      "sortBy": "area_desc",
      "selectors": [
        "article img",
        ".content img",
        ".arcbody img",
        ".gl-content img",
        ".main img",
        ".detail img",
        ".news_con img",
        ".text img",
        ".showcont img",
        ".wz_con img",
        ".cont img",
        ".con img",
        "img"
      ],
      "contentHints": [
        "article",
        "content",
        "arcbody",
        "gl-content",
        "main",
        "detail",
        "news_con",
        "text",
        "showcont",
        "wz_con",
        "cont",
        "con",
        "正文"
      ],
      "excludeHints": [
        "right",
        "side",
        "rank",
        "hot",
        "recommend",
        "footer",
        "header",
        "nav",
        "menu",
        "search",
        "login",
        "app",
        "ad",
        "广告"
      ],
      "extraAttributes": [
        "data-original",
        "data-src",
        "data-url",
        "data-lazy"
      ],
      "imageUrlKeywords": [
        "ali213.net",
        "ali213.com",
        ".jpg",
        ".png",
        ".webp",
        ".gif"
      ],
      "tips": "游侠页面已默认过滤 80px 以下小碎图。点「正文图」优先看当前游戏文章图片；点「大图」只看大素材。"
    },
    "mp.weixin.qq.com": {
      "enabled": true,
      "label": "微信公众号文章",
      "minSizeDefault": 10,
      "sortBy": "area_desc",
      "selectors": [
        "#js_content img",
        ".rich_media_content img",
        "img"
      ],
      "contentHints": [
        "js_content",
        "rich_media_content"
      ],
      "extraAttributes": [
        "data-src",
        "data-backsrc",
        "data-croporisrc",
        "data-w",
        "data-ratio"
      ],
      "imageUrlKeywords": [
        "mmbiz.qpic.cn",
        "wx_fmt=jpg",
        "wx_fmt=png",
        "wx_fmt=webp"
      ],
      "tips": "微信图片通常懒加载，先滚到图片位置再刷新插件。"
    }
  }
}