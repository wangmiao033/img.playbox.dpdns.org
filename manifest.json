{
  "manifest_version": 3,
  "name": "素材猎手 - Image Hunter",
  "short_name": "素材猎手",
  "version": "0.3.1",
  "description": "扫描当前网页图片，按格式、尺寸和素材类型筛选，支持侧边栏批量下载和二次确认。",
  "action": {
    "default_title": "素材猎手",
    "default_icon": "assets/icon.svg"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "assets/icon.svg",
    "32": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  }
}